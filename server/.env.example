PORT=5000
MONGODB_URI=
REDIS_URL=
JWT_SECRET=

# ── Email: Gmail SMTP (recommended — sends to any real inbox) ─────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Go to: Google Account → Security → 2-Step Verification → App passwords
# 3. Create an app password, paste the 16-char code below (spaces are fine)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Display name in the From field
EMAIL_FROM=Teamgrid CRM <you@gmail.com>

# ── Email: Resend (fallback if GMAIL_USER is not set) ─────────────────────
# Limited to your own email unless you verify a custom domain at resend.com
RESEND_API_KEY=

# ── Other integrations ────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
PANDADOC_API_KEY=
REPORT_EMAIL_RECIPIENT=
CLIENT_URL=http://localhost:5173

# Set to true to enable the /api/webhooks/test-drip QA endpoint
ALLOW_TEST_DRIP=true
